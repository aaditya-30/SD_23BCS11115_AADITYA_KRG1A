        </mxCell>
        <mxCell id="WwPvpsgi1mnFVvuXdcWM-122" parent="WwPvpsgi1mnFVvuXdcWM-150" style="text;whiteSpace=wrap;html=1;" value="&lt;span style=&quot;color: rgb(255, 255, 255); font-family: Helvetica; font-size: 12px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: normal; background-color: rgb(27, 29, 30); text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial; display: inline !important; float: none;&quot;&gt;EACH PAYMENT of the cart HAS A TIMER OF 10 MINUTES. TILL THE END OF 10 MINUTES THE ITEM IS ON HOLD TO BE ORDERED BY SOMEONE ELSE&lt;/span&gt;" vertex="1">
