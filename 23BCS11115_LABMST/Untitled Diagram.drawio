    <mxGraphModel dx="1994" dy="174" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="WwPvpsgi1mnFVvuXdcWM-1" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;DESIGN AN ECOMMERCE SYSTEM WITH FOLLOWING REQUIREMENTS&lt;/div&gt;&lt;div&gt;USER LOGIN&lt;/div&gt;&lt;div&gt;SEARCH&amp;nbsp;&lt;/div&gt;&lt;div&gt;\PRODUCT CATALOG&lt;/div&gt;&lt;div&gt;CART&lt;/div&gt;&lt;div&gt;ORDER STATUS&lt;/div&gt;&lt;div&gt;CHECKOUT&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;OPTIMIZE THE PRODUCT SEARCHING AND INVENTORY MANAGEMENT&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="210" width="730" x="50" y="80" as="geometry" />
        </mxCell>
        <mxCell id="WwPvpsgi1mnFVvuXdcWM-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;FUNCTIONAL REQUIREMENTS:&lt;/b&gt;&lt;div&gt;1. USER SHOULD BE ABLE TO SEARCH AND BROWSE PRODUCT LIST WITHOUT LOGIN&lt;/div&gt;&lt;div&gt;2. USER SHOULD BE ABLE TO ADD PRODUCTS TO CART&lt;/div&gt;&lt;div&gt;3. USER SHOULD BE ABLE TO PAY THROUGH A PAYMENT GATEWAY OR COD&lt;/div&gt;&lt;div&gt;4. USER SHOULD BE ABLE TO ORDER A PRODUCT AND CANCEL IF NEEDED&lt;/div&gt;&lt;div&gt;5. USER SHOULD BE ABLE TO CHECK THE STATUS OF THE ORDERED PRODUCT&lt;/div&gt;&lt;div&gt;6. USER SHOULD BE ABLE TO LOGIN&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="530" x="60" y="340" as="geometry" />
        </mxCell>
        <mxCell id="WwPvpsgi1mnFVvuXdcWM-3" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;b&gt;NON FUNCTIONAL REQUIREMENTS&quot;&lt;/b&gt;&lt;div&gt;&lt;b&gt;1. &lt;/b&gt;THE SYSTEM SHOULD BE ABLE TO HANDLE A LOAD OF 1M TO 1.5M DAU&lt;/div&gt;&lt;div&gt;2. USER CAN DO 2-FACTOR-AUTHENTICATION&lt;/div&gt;&lt;div&gt;3. AVAILABILITY&amp;gt;CONSISTENCY&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="490" x="90" y="530" as="geometry" />
        </mxCell>
