        <mxCell id="WwPvpsgi1mnFVvuXdcWM-145" parent="WwPvpsgi1mnFVvuXdcWM-150" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="KAFKA ESSENTIALLY REDUCES THE NUMBER OF API CALLS BY IMPLEMENTING A PRODUCER- CONSUMER ARCHITECTURE&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;HOW IT DOES?&lt;/div&gt;&lt;div&gt;ANS: WHENEVER A PAYMENT IS MADE SUCCESSFULLY, THE DETAILS ARE STORED IN KAFKA AND IT ACTS AS A PRODUCER&lt;br&gt;&lt;br&gt;NOW ALL THE DATABASE SERVICES WHICH ARE OUR CONSUEMER THAT NEEDS THE REQUIRED DATA CAN GET IT FROM THE PRODUCER&amp;nbsp;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
