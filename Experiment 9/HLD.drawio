        <mxCell id="Yea9uvm68PrgL9xSrtvl-54" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213E;strokeColor=#00B4D8;strokeWidth=2;arcSize=8;shadow=1;" value="" vertex="1">
          <mxGeometry height="280" width="460" x="80" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-55" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=16;fontColor=#00B4D8;fontFamily=Helvetica;" value="⚡ Functional Requirements" vertex="1">
          <mxGeometry height="30" width="400" x="100" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-56" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=11;fontColor=#BFCFDC;fontFamily=Helvetica;spacing=8;" value="&lt;b style=&#39;color:#48BFE3&#39;&gt;1. Search Functionality&lt;/b&gt;&lt;br&gt;Users can discover events using filters — Event Title, City/Location, and Date of the show.&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#48BFE3&#39;&gt;2. Event Information Display&lt;/b&gt;&lt;br&gt;View comprehensive event details: Seats (available vs. occupied), Description, and Metadata (cast, duration, language, ratings).&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#48BFE3&#39;&gt;3. Booking Execution&lt;/b&gt;&lt;br&gt;Select a seat and complete a transaction to book a ticket." vertex="1">
          <mxGeometry height="230" width="430" x="90" y="1095" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-57" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213E;strokeColor=#E94560;strokeWidth=2;arcSize=8;shadow=1;" value="" vertex="1">
          <mxGeometry height="280" width="460" x="580" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-58" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=16;fontColor=#E94560;fontFamily=Helvetica;" value="🛡️ Non-Functional Requirements" vertex="1">
          <mxGeometry height="30" width="400" x="600" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-59" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=11;fontColor=#BFCFDC;fontFamily=Helvetica;spacing=8;" value="&lt;b style=&#39;color:#F77F00&#39;&gt;Target Scale&lt;/b&gt;&lt;br&gt;100 Million Daily Active Users (DAU).&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#F77F00&#39;&gt;High Availability&lt;/b&gt;&lt;br&gt;Search and view operations must be &quot;always online&quot;. Better to show slightly older data than an error page.&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#F77F00&#39;&gt;High Consistency&lt;/b&gt;&lt;br&gt;Booking operations must be highly consistent. Two people must never book the same seat simultaneously." vertex="1">
          <mxGeometry height="230" width="440" x="590" y="1095" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-60" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A1A2E;strokeColor=#533483;strokeWidth=2;arcSize=6;shadow=1;" value="" vertex="1">
          <mxGeometry height="480" width="520" x="80" y="1380" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-61" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=16;fontColor=#C77DFF;fontFamily=Helvetica;" value="📡 API Designs" vertex="1">
          <mxGeometry height="30" width="300" x="100" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-62" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=11;fontColor=#A0B0C0;fontFamily=Courier New;spacing=8;" value="&lt;b style=&#39;color:#00B4D8&#39;&gt;── Auth ──&lt;/b&gt;&lt;br&gt;POST /api/v1/auth/signup&lt;br&gt;POST /api/v1/auth/login&lt;br&gt;GET  /api/v1/users/me&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#5E60CE&#39;&gt;── Events ──&lt;/b&gt;&lt;br&gt;POST /api/v1/events&lt;br&gt;GET  /api/v1/events/{eventId}&lt;br&gt;GET  /api/v1/events?location=&amp;amp;date=&amp;amp;page=&amp;amp;limit=&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#48BFE3&#39;&gt;── Search ──&lt;/b&gt;&lt;br&gt;GET  /api/v1/search?q=&amp;amp;location=&amp;amp;date=&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#F77F00&#39;&gt;── Bookings ──&lt;/b&gt;&lt;br&gt;POST /api/v1/bookings&lt;br&gt;POST /api/v1/bookings/{bookingId}/confirm&lt;br&gt;GET  /api/v1/bookings/my?page=&amp;amp;limit=&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#D62828&#39;&gt;── Payments ──&lt;/b&gt;&lt;br&gt;POST /api/v1/payments&lt;br&gt;POST /api/v1/payments/webhook" vertex="1">
          <mxGeometry height="420" width="480" x="90" y="1425" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-63" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A1A2E;strokeColor=#0F3460;strokeWidth=2;arcSize=6;shadow=1;" value="" vertex="1">
          <mxGeometry height="480" width="460" x="640" y="1380" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-64" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=16;fontColor=#48BFE3;fontFamily=Helvetica;" value="🗄️ Database Schema" vertex="1">
          <mxGeometry height="30" width="300" x="660" y="1390" as="geometry" />
        </mxCell>
        <mxCell id="Yea9uvm68PrgL9xSrtvl-65" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontSize=10;fontColor=#A0B0C0;fontFamily=Courier New;spacing=8;" value="&lt;b style=&#39;color:#00B4D8&#39;&gt;users&lt;/b&gt; {&lt;br&gt;  id BIGINT PK, name VARCHAR(100),&lt;br&gt;  email VARCHAR(100) UNIQUE,&lt;br&gt;  password_hash TEXT, created_at TIMESTAMP&lt;br&gt;}&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#5E60CE&#39;&gt;events&lt;/b&gt; {&lt;br&gt;  id BIGINT PK, title VARCHAR(255),&lt;br&gt;  location VARCHAR(100), date TIMESTAMP,&lt;br&gt;  total_seats INT, available_seats INT,&lt;br&gt;  created_at TIMESTAMP&lt;br&gt;}&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#F77F00&#39;&gt;seats&lt;/b&gt; {&lt;br&gt;  id BIGINT PK, event_id BIGINT,&lt;br&gt;  seat_number INT,&lt;br&gt;  status ENUM(&#39;AVAILABLE&#39;,&#39;LOCKED&#39;,&#39;BOOKED&#39;),&lt;br&gt;  UNIQUE(event_id, seat_number)&lt;br&gt;}&lt;br&gt;&lt;br&gt;&lt;b style=&#39;color:#D62828&#39;&gt;bookings&lt;/b&gt; {&lt;br&gt;  id BIGINT PK, user_id BIGINT,&lt;br&gt;  event_id BIGINT,&lt;br&gt;  status ENUM(&#39;PENDING&#39;,&#39;CONFIRMED&#39;,&#39;FAILED&#39;),&lt;br&gt;  total_amount DECIMAL, created_at TIMESTAMP&lt;br&gt;}" vertex="1">
          <mxGeometry height="420" width="420" x="650" y="1425" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
